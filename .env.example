# ===========================================================================
# AI Medical Report Analyser - Environment Configuration Example
# ===========================================================================
# Copy this file to .env and configure at least one of the keys below.
# Restart your Flask server after editing .env.

# Flask settings
SECRET_KEY=your_super_secret_flask_key_here

# ---------------------------------------------------------------------------
# Open Source LLM Providers (Configure at least one!)
# ---------------------------------------------------------------------------

# 1. SambaNova Key (Recommended - Incredibly fast, massive free tier, Llama 3.1)
# Get a free key at: https://cloud.sambanova.ai/
SAMBANOVA_API_KEY=your_sambanova_api_key_here

# 2. Groq Key (Free open-source alternative)
# Get a free key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# 3. OpenRouter Key (Completely free models)
# Get a free key at: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 4. Hugging Face API Token
# Get a free token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=your_hf_token_here